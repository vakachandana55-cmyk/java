public class numbers {

	public static void main(String[] args) {
		int i,k,j;
		
		int n=5;
		
		for(i=1;i<=n;i++)
		{
		    	for(j=1;j<=n-i;j++)
		    	{
		    	     System.out.print(" *");
		    	}
		    
			for(k=1;k<=i;k++)
			{
				System.out.print(" ");
				
				
			}
				System.out.println();
		}
	}
}
